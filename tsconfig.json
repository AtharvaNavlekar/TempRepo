{
    "compilerOptions": {
        "lib": [
            "dom",
            "dom.iterable",
            "esnext"
        ],
        "allowJs": true,
        "skipLibCheck": true,
        "strict": true,
        "noEmit": true,
        "esModuleInterop": true,
        "module": "esnext",
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "jsx": "preserve",
        "incremental": true,
        "plugins": [
            {
                "name": "next"
            }
        ],
        "baseUrl": "./client",
        "paths": {
            "@/*": [
                "./src/*"
            ]
        },
        "target": "ES2017"
    },
    "include": [
        "client/next-env.d.ts",
        "client/**/*.ts",
        "client/**/*.tsx",
        "client/.next/types/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "client/node_modules"
    ]
}